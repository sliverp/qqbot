# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# QQBot E2E 测试配置 / E2E Test Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 复制为 .env 并填写真实值 / Copy to .env and fill in real values:
#   cp tests/.env.example tests/.env
#
# ⚠️ 绝对不要把 .env 提交到 Git！/ NEVER commit .env to Git!
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── Bot 1（默认账户 / default account） ──────────────────────────────
BOT1_APPID=111111111
BOT1_SECRET=your-bot1-app-secret
BOT1_TEST_OPENID=AAAAAAAA-BBBB-CCCC-DDDD-EEEEEEEEEEEE

# ── Bot 2（第二个机器人 / second bot） ───────────────────────────────
BOT2_APPID=222222222
BOT2_SECRET=your-bot2-app-secret
BOT2_TEST_OPENID=FFFFFFFF-GGGG-HHHH-IIII-JJJJJJJJJJJJ

# ── 可选：群消息测试 / Optional: group message test ─────────────────
# BOT1_TEST_GROUP_OPENID=GROUP_OPENID_FOR_BOT1
# BOT2_TEST_GROUP_OPENID=GROUP_OPENID_FOR_BOT2

# ── 可选：文件消息测试图片 / Optional: image for file message test ──
# TEST_IMAGE_PATH=/path/to/test-image.png

# ── OpenClaw 版本列表 / OpenClaw versions to test ───────────────────
# 逗号分隔，run-tests.sh 会为每个版本启动一个 Docker 容器
# Comma-separated; run-tests.sh spawns one Docker container per version
OPENCLAW_VERSIONS=latest
# 示例 / Example: OPENCLAW_VERSIONS=latest,1.20.0,1.19.5

# ── 用于 docker-compose 中 pinned 服务的版本 ────────────────────────
# OPENCLAW_PINNED_VERSION=1.20.0
